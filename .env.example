# Env vars consumed by docker-compose.yml. Copy to `.env` on each host
# (prod + dev) and fill in. Never commit a populated .env.

# ---- Required on every host ----
DB_PASSWORD=change-me
JWT_SECRET=change-me-long-random-string

# ---- Hostname the app answers on (Traefik Host rule) ----
# Prod:  quoter.doublevpartners.com           (or leave unset for the default)
# Dev:   dev.quoter.doublevpartners.com
DVPNYX_HOST=quoter.doublevpartners.com

# ---- URL the backend returns to the browser (CORS + frontend fetch base) ----
# Use https to match Traefik's TLS-only entrypoint.
CLIENT_URL=https://quoter.doublevpartners.com

# ---- HTTP Basic Auth (optional — leave empty in prod, set in dev) ----
# 1. Generate a hash:  htpasswd -nbB preview 'your-password'
#    Example output:   preview:$2y$05$...
# 2. In docker-compose labels the $ must be escaped by doubling. Do that
#    BEFORE pasting here:
#      preview:$$2y$$05$$...
# 3. Reference the middleware so Traefik actually applies it:
# DVPNYX_BASIC_AUTH=preview:$$2y$$05$$replace-with-real-bcrypt-hash
# DVPNYX_AUTH_MIDDLEWARE=dvpnyx-auth@docker

# ---- Build-time vars (set automatically by the GH Actions deploy) ----
# If you build manually on the box, export these before `docker compose build`
# so the Footer shows the exact commit in the browser.
# REACT_APP_GIT_SHA=abc1234
# REACT_APP_VERSION=2.0.0
